@startuml

' ========================
' Single Interface
' ========================

interface IValidationComponent {
  + execute(): void
}

' ========================
' Classes
' ========================

class DataValidationManagement {
  + validateIncomingData(): void
  + coordinateValidation(): void
}

class EnsureMQTTCompliance {
  + parsePacket(): boolean
  + validateMQTTFormat(): boolean
}

class SensorMonitor {
  + monitorSensorData(): void
  + detectAnomalies(): boolean
}

class StoreValidatedData {
  + storeData(): void
  + sendToTimeSeriesDB(): void
}

class ValidationEventLog {
  + logEvent(): void
  + attachTimestamp(): void
}

class ValidSensorDataDB {
  + store(): void
  + retrieveHistoricalData(): List
}

' ========================
' Interface Implementation
' ========================

IValidationComponent <|.. EnsureMQTTCompliance : implements
IValidationComponent <|.. SensorMonitor : implements
IValidationComponent <|.. StoreValidatedData : implements

' ========================
' Controller depends on interface
' ========================

DataValidationManagement --> IValidationComponent : uses / depends on

' ========================
' Other relationships (labeled)
' ========================

EnsureMQTTCompliance --> ValidationEventLog : logs events
SensorMonitor --> ValidSensorDataDB : reads historical data
StoreValidatedData --> ValidSensorDataDB : stores validated data

@enduml