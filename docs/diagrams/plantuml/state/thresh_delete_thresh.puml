@startuml thresh_delete_threshold

[*] --> ReceiveDeleteRequest : deleteThreshold(id)

ReceiveDeleteRequest --> RetrieveThreshold

RetrieveThreshold --> Error : threshold not found
RetrieveThreshold --> DeleteThreshold : threshold found

DeleteThreshold --> UpdateRepository

UpdateRepository --> Success : deletion stored
UpdateRepository --> Error : deletion failed

Success --> [*]
Error --> [*]

@enduml